# Optional direct API providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
WITNESS_MODEL=

# Codex CLI OAuth provider. Sign in separately with `codex login`.
WITNESS_CODEX_PATH=codex
WITNESS_CODEX_PROFILE=
WITNESS_CODEX_SANDBOX=read-only

# Generic no-key host/local model bridge. The command reads one JSON request
# from stdin and prints one schema-valid Witness decision JSON object.
WITNESS_AGENT_COMMAND=

# Optional replay of decisions exported by Claude Code/Codex.
WITNESS_DECISION_FILE=
